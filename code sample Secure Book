// Define a function to generate a digital signature
int generate_signature(const unsigned char  data, size_t data_len, unsigned char   signature, size_t  signature_len) {
    // Generate a private key
    RSA  private_key = RSA_new();
    BIGNUM  exponent = BN_new();
    BN_set_word(exponent, 65537);
    RSA_generate_key_ex(private_key, 2048, exponent, NULL);
    // Generate a signature
    unsigned char  sig = malloc(RSA_size(private_key));
    unsigned int sig_len = RSA_size(private_key);
    RSA_sign(NID_sha256, data, data_len, sig, &sig_len, private_key);
    // Return the signature
     signature = sig;
     signature_len = sig_len;
    return 0;
}
// Define a function to verify a digital signature
int verify_signature(const unsigned char  data, size_t data_len, const unsigned char  signature, size_t signature_len) {
    // Generate a public key
    RSA  public_key = RSA_new();
    BIGNUM● exponent = BN_new();
    BN_set_word(exponent, 65537);
    RSA_generate_key_ex(public_key, 2048, exponent, NULL);
    // Verify the signature
    int result = RSA_verify(NID_sha256, data, data_len, signature, signature_len, public_key);
    return result;
}
